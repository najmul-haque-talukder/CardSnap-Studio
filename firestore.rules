rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for templates collection
    match /templates/{templateId} {
      // Anyone can read published templates
      allow read: if resource.data.status == 'published';
      
      // Allow anyone to update ONLY the usageCount of a published template
      allow update: if resource.data.status == 'published' 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']);
      
      // Full access (read, create, update, delete) for authenticated users (Admins)
      allow read, write: if request.auth != null;
    }
    
    // Default rule for all other documents - requires authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}