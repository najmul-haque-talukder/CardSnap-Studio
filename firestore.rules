rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /templates/{templateId} {
      // Anyone can read published templates
      allow read: if resource.data.status == 'published';
      
      // Allow anyone to update the usageCount of a published template
      allow update: if resource.data.status == 'published' 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']);
      
      // Only authenticated users can read drafts and perform full writes
      allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}